        "unit": "g",
        "notes": ""
      },
      {
        "name": "芝麻香油",
        "bind_to": "total",
        "rule": {
          "type": "pct_of_main",
          "value": 20
        },
        "round": {
          "step": 1,
          "mode": "nearest"
